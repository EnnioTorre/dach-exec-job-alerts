# Google provider-backed scraping configuration
# Copy to .env.google-providers and fill in real values:
#   cp .env.google-providers.example .env.google-providers
# The real .env.google-providers is git-ignored; never commit real keys here.

# --- Required for local TLS trust in this environment ---
SCRAPER_CA_BUNDLE=/etc/pki/tls/certs/ca-bundle.crt

# --- Google mode ---
# provider_only: provider APIs only (no direct Google SERP fetch)
# hybrid: provider first, then direct fetch fallback
# direct: direct fetch only
# off: disable google_proxy sources
SCRAPER_GOOGLE_MODE=provider_only

# Avoid Google fallback URLs from search_proxy retry chains
SCRAPER_AVOID_GOOGLE_FALLBACKS=1

# Keep flaky search proxies disabled by default
SCRAPER_SKIP_SEARCH_PROXIES=1

# Optional scrape runtime settings
SCRAPER_FAIL_ON_FETCH_ERROR=false
SCRAPER_ENRICH_MAX=0

# --- Provider options (set at least one) ---
# 1) Google Custom Search (official API)
SCRAPER_GOOGLE_CSE_KEY=
SCRAPER_GOOGLE_CSE_CX=

# 2) SerpAPI
SCRAPER_SERPAPI_KEY=

# 3) Zenserp
SCRAPER_ZENSERP_KEY=

# 4) SearXNG (self-hosted or managed)
SCRAPER_SEARXNG_URL=
SCRAPER_SEARXNG_KEY=
